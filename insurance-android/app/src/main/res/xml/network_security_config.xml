<?xml version="1.0" encoding="utf-8"?>
<!--
  Local / lab HTTP (e.g. http://192.168.x.x:5000) with user-configured base URL.

  Android cannot whitelist arbitrary IP ranges in network_security_config; listing single hosts
  (like 192.168.1.10) breaks when the laptop IP changes. Using base-config allows cleartext to
  any host the app connects to — appropriate for this LAN-only tooling app.

  For production apps on the public internet, prefer HTTPS and set cleartextTrafficPermitted
  to false (or use a release build overlay with a stricter config).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
