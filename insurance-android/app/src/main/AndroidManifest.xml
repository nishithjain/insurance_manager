<?xml version="1.0" encoding="utf-8"?>
<!--
  Main manifest.
  Cleartext HTTP for configurable LAN backends: see res/xml/network_security_config.xml.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Package visibility: resolve WhatsApp / wa.me handlers on API 30+ -->
    <queries>
        <package android:name="com.whatsapp" />
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" android:host="wa.me" />
        </intent>
        <intent>
            <action android:name="android.intent.action.DIAL" />
            <data android:scheme="tel" />
        </intent>
    </queries>

    <!-- Needed for Retrofit / OAuth browser / image URLs -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".InsuranceApp"
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher_foreground"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@drawable/ic_launcher_foreground"
        android:supportsRtl="true"
        android:theme="@style/Theme.InsuranceMobile"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.InsuranceMobile">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
